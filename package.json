{
  "name": "mana-bar",
  "displayName": "mana.bar",
  "description": "Track usage limits across multiple LLM services (Claude Code, Codex, VSCode Copilot, Copilot CLI, Cursor, Antigravity, Gemini, Kiro)",
  "version": "0.0.5",
  "publisher": "binhonglee",
  "engines": {
    "vscode": "^1.93.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/binhonglee/mana-bar.git"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "assets/logo.png",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "manaBar.refresh",
        "title": "Refresh Usage Data",
        "category": "mana.bar"
      },
      {
        "command": "manaBar.openSettings",
        "title": "Open Settings",
        "category": "mana.bar"
      },
      {
        "command": "manaBar.openDashboard",
        "title": "Open Dashboard",
        "category": "mana.bar"
      },
      {
        "command": "manaBar.reportOutage",
        "title": "Report AI Service Outage",
        "category": "mana.bar"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "manaBar",
          "title": "mana.bar",
          "icon": "assets/alt.svg"
        }
      ]
    },
    "views": {
      "manaBar": [
        {
          "id": "manaBarSidebar",
          "name": "Usage Overview"
        }
      ]
    },
    "configuration": {
      "title": "mana.bar",
      "properties": {
        "manaBar.pollingInterval": {
          "type": "number",
          "default": 120,
          "minimum": 10,
          "maximum": 300,
          "description": "Polling interval in seconds (10s - 5min)"
        },
        "manaBar.displayMode": {
          "type": "string",
          "enum": [
            "used",
            "remaining"
          ],
          "enumDescriptions": [
            "Show how much quota has been used.",
            "Show how much quota is left."
          ],
          "default": "remaining",
          "description": "Whether quota values are displayed as used or remaining."
        },
        "manaBar.statusBarTooltipLayout": {
          "type": "string",
          "enum": [
            "regular",
            "monospaced"
          ],
          "enumDescriptions": [
            "Show the status bar hover in the regular table style.",
            "Show the status bar hover in a fixed-width monospaced layout."
          ],
          "default": "regular",
          "description": "How the status bar hover tooltip is laid out."
        },
        "manaBar.debugLogs": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose debug logging in the extension host console."
        },
        "manaBar.hiddenServices": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of service names hidden from sidebar and status bar"
        },
        "manaBar.services": {
          "type": "object",
          "default": {
            "claudeCode": {
              "enabled": true
            },
            "codex": {
              "enabled": true
            },
            "vscodeCopilot": {
              "enabled": true
            },
            "copilotCli": {
              "enabled": true
            },
            "cursor": {
              "enabled": true
            },
            "antigravity": {
              "enabled": true
            },
            "gemini": {
              "enabled": true
            },
            "kiro": {
              "enabled": true
            }
          },
          "description": "Enable or disable usage tracking for each supported service."
        },
        "manaBar.copilotCliModels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "claude-sonnet-4.6",
            "gpt-5.2"
          ],
          "description": "Copilot CLI models to probe for outage detection"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "build:webview": "tsc -p tsconfig.webview.json",
    "compile": "tsc -p ./ && npm run build:webview",
    "watch:webview": "tsc -watch -p tsconfig.webview.json",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "playwright:install": "playwright install chromium",
    "build:test-e2e": "tsc -p tests/e2e/tsconfig.json",
    "test": "npm run test:unit",
    "test:unit": "vitest run --config vitest.config.ts --coverage",
    "test:browser": "npm run build:webview && playwright test --config playwright.config.ts",
    "test:e2e": "npm run build:test-e2e && node out-test/e2e/run-tests.js",
    "test:all": "npm run test:unit && npm run test:browser && npm run test:e2e",
    "test:ci": "npm run compile && npm run test:unit && npm run test:browser && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.0",
    "@types/vscode": "1.116.0",
    "@vitest/coverage-v8": "4.1.4",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.9.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
